# =============================================================================
# SITREP — Environment Variables
# =============================================================================
# cp .env.example .env && vim .env

# Discord Webhook URL for alerts
DISCORD_WEBHOOK_URL=CHANGEME_DISCORD_WEBHOOK_URL

# Port to listen on (default: 3333)
PORT=3333

# Polling interval in ms (default: 30000 = 30s)
POLL_INTERVAL=30000

# SSL cert expiry alert threshold in days (default: 14)
CERT_EXPIRY_ALERT_DAYS=14

# Mock mode: simulate health responses (no production polling)
# Set to "true" for local dev/testing
MOCK_MODE=false

# Log level: debug, info, warn, error, fatal (default: debug in dev, info in prod)
# LOG_LEVEL=debug

# Optional: Prometheus URL for database metrics
# PROMETHEUS_URL=http://prometheus.monitoring.svc:9090

# Optional: External targets JSON file (overrides embedded config.js targets)
# Use this for K8s ConfigMap or Docker volume mount
# SITREP_TARGETS_FILE=/etc/sitrep/targets.json

# =============================================================================
# MONITORING HUB — Collectors Configuration
# =============================================================================

# GitHub API token (required for GitHub collector)
# Scopes: repo, read:org
# GITHUB_TOKEN=ghp_xxxx
# GITHUB_ORG=bdelpech

# Neo4j Code Graph (required for Code Intelligence collector)
# NEO4J_BOLT_URL=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# Notion API token (required for Roadmap/Planning sync)
# Create an internal integration at https://www.notion.so/my-integrations
# NOTION_API_TOKEN=ntn_xxxx
# NOTION_ROADMAP_DB_ID=169cddf4-fe48-80be-90b8-f24e21c75ff9

# Hetzner Cloud API token (optional, for live cost data)
# HETZNER_API_TOKEN=

# Finance config file override (JSON)
# SITREP_FINANCE_FILE=/etc/sitrep/finance.json
